# =============================================================================
# API Keys — numbered, tried in order on rate-limit (429) or auth error (401/403)
# =============================================================================
# Anthropic native key: starts with sk-ant-
# OpenRouter key:       starts with sk-or-
#
# Add as many as you like. The system falls back to the next key automatically.
API_KEY_1=sk-ant-your-anthropic-key-here
# API_KEY_2=sk-or-your-openrouter-key-here
# API_KEY_3=sk-ant-your-backup-anthropic-key

# Backwards-compatible single key (used only when no API_KEY_N entries exist)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# =============================================================================
# OpenRouter settings (only needed when using sk-or- keys)
# =============================================================================
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SONNET_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_HAIKU_MODEL=anthropic/claude-haiku-4-5
#
# Find model names at: https://openrouter.ai/models

# =============================================================================
# Workspace location
# =============================================================================
# Set to any absolute path on your system.
# Windows:   WORKSPACE_ROOT=C:\Users\you\projects\workspaces
# Mac/Linux: WORKSPACE_ROOT=/home/you/projects/workspaces
# Default (relative to glowing-spoon directory):
WORKSPACE_ROOT=./workspaces

# =============================================================================
# Storage backend (local only — Phase 1)
# =============================================================================
STORAGE=local

# =============================================================================
# Phase 2 (do not build yet)
# =============================================================================
# DATABASE_URL=
# AUTH_SECRET=

# =============================================================================
# Phase 3 (do not build yet)
# =============================================================================
# AWS_BUCKET=
# AWS_REGION=
