# =============================================================================
# OpenRouter API Key (required)
# Get yours at: https://openrouter.ai/keys
# =============================================================================
OPENROUTER_API_KEY=sk-or-your-key-here

# Override the OpenRouter endpoint (optional — defaults to the URL below).
# Must be https:// (or localhost, for a local proxy). Never point this at an
# untrusted host — your API key is sent as the Bearer token.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# Provider keys — add these in your OpenRouter account, NOT here
# Go to: https://openrouter.ai/settings/keys  → "Provider Keys"
#
#   Anthropic  → for Claude Sonnet and Haiku (used by default)
#   OpenAI     → for GPT-4o and GPT-4o Mini
#   Google     → for Gemini Pro and Gemini Flash
#
# OpenRouter routes through your provider keys, so you control billing directly.
# =============================================================================

# =============================================================================
# Model selection (optional) — pick any models from: https://openrouter.ai/models
# =============================================================================
# OPTION A — model pool (recommended with free models):
# Comma-separated list; ALL agents rotate through it round-robin. When a model
# is rate-limited (429) or unavailable, the next one is tried automatically;
# if every model is down, the call waits (15s, 30s, 60s… up to 2 min between
# cycles) and keeps trying for up to 30 minutes (MODEL_RETRY_MAX_MS).
# Models ending in ":free" are billed as $0 in the session budget.
#
# Model ids age out — verify each one exists before use (https://openrouter.ai/models).
# A model that 404s twice mid-session is pruned from the rotation automatically,
# and a pool collapsed onto one surviving model blocks the session for a PM
# decision (MODEL_POOL_DEGRADED) instead of silently building on it.
# Tip: end the pool with one cheap PAID model (billed to the session budget) as a
# quality floor — it always answers, so the pool never collapses onto a weak free model.
# MODEL_POOL=qwen/qwen3-coder:free,cohere/north-mini-code:free,openai/gpt-oss-20b:free,meta-llama/llama-3.3-70b-instruct:free,google/gemma-4-31b-it:free,tencent/hy3:free,google/gemini-3.1-flash-lite
# MODEL_RETRY_MAX_MS=1800000

# OPTION B — two-tier split (used when MODEL_POOL is not set):
# Reasoning agents (agent-pm, spec-agent, dev-agent, review-agent):
# REASONING_MODEL=anthropic/claude-sonnet-4

# Fast agents (qa-agent, docs-agent, quality-scorer, skill-resolver):
# FAST_MODEL=anthropic/claude-haiku-4-5

# Other popular choices:
#   openai/gpt-4o           openai/gpt-4o-mini
#   google/gemini-pro-1.5   google/gemini-2.0-flash-001

# =============================================================================
# Workspace location (optional — defaults to ./workspaces)
# On a server deployment, always use an ABSOLUTE path.
# =============================================================================
# Windows:   WORKSPACE_ROOT=C:\Users\you\projects\workspaces
# Mac/Linux: WORKSPACE_ROOT=/home/you/projects/workspaces
WORKSPACE_ROOT=./workspaces

# =============================================================================
# Web UI server (npm run serve) — see docs/deploy.md
# =============================================================================
# Port the web server listens on
PORT=3808

# Cookie-signing secret (REQUIRED in production, >= 32 random chars).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_SECRET=

# Set true when serving over HTTPS (behind nginx/caddy TLS)
# COOKIE_SECURE=true

# How long a session waits for a decision before stopping (resumable).
# Web users respond asynchronously — 24h is a good server default.
# POLL_TIMEOUT_MS=86400000

# =============================================================================
# Misc (optional)
# =============================================================================
# Enables development behavior in server/config.js (ephemeral SESSION_SECRET
# fallback, COOKIE_SECURE off). Set to "production" on a real deployment —
# SESSION_SECRET then becomes required and the server refuses to start without it.
# NODE_ENV=production

# Verbose diagnostic logging to stderr (utils/logger.js)
# GLOWING_DEBUG=true
